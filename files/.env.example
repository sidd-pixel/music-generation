# ─────────────────────────────────────────────
#  AI Music Generator (Python) — Environment
# ─────────────────────────────────────────────

# Server
PORT=8000
HOST=0.0.0.0
ENV=development               # development | production

# ── Groq (Lyrics) ─────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── ElevenLabs (Voice TTS) ────────────────────
ELEVEN_API_KEY=your_elevenlabs_api_key_here
# Voice ID — default is "Rachel". Browse IDs at https://api.elevenlabs.io/v1/voices
ELEVEN_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Local MusicGen ────────────────────────────
# Model sizes:  facebook/musicgen-small   (~300MB, fast CPU)
#               facebook/musicgen-medium  (~1.5GB, better quality)
#               facebook/musicgen-large   (~3.3GB, best quality)
#               facebook/musicgen-melody  (prompt + melody conditioning)
MUSICGEN_MODEL=facebook/musicgen-small
MUSICGEN_DURATION=10          # seconds of music to generate
MUSICGEN_USE_GPU=false        # true = use CUDA if available

# ── Concurrency ───────────────────────────────
MAX_CONCURRENT_JOBS=2         # generation jobs that run in parallel
JOB_TIMEOUT_SECONDS=180
